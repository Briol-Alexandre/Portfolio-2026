{
  "name": "tailwind-blank",
  "version": "1.0.0",
  "description": "A clean, minimal WordPress theme built with Tailwind CSS",
  "scripts": {
    "dev": "npx tailwindcss -i ./src/style.css -o ./dist/style.css --watch",
    "build": "npx tailwindcss -i ./src/style.css -o ./dist/style.css --minify"
  },
  "keywords": [
    "wordpress",
    "theme",
    "tailwind"
  ],
